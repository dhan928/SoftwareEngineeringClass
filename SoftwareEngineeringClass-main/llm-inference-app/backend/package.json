{
  "name": "llm-inference-backend",
  "version": "1.0.0",
  "description": "Backend API for LLM Inference Web Application",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node ./node_modules/jasmine/bin/jasmine.js tests/validators.spec.js tests/userService.spec.js tests/conversationService.spec.js tests/llmService.spec.js",
    "test:watch": "nodemon --exec jasmine",
    "test:fast": "node ./node_modules/jasmine/bin/jasmine.js tests/validators.spec.js tests/userService.spec.js",
    "test:cucumber": "cucumber-js features/**/*.feature --require features/step_definitions/steps.js",
    "test:unit": "node ./node_modules/jasmine/bin/jasmine.js tests/validators.spec.js tests/userService.spec.js tests/conversationService.spec.js tests/llmService.spec.js",
    "test:e2e": "jasmine tests/e2e.spec.js --timeout=120000",
    "test:all": "node ./node_modules/jasmine/bin/jasmine.js tests/**/*.spec.js --timeout=120000"
  },
  "keywords": [
    "llm",
    "inference",
    "api",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "jasmine": "^4.6.0",
    "jasmine-core": "^4.6.0",
    "nodemon": "^2.0.22",
    "puppeteer": "^24.39.1"
  }
}
